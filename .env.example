# ── Copy this file to .env and fill in your values ───────────────────────────
# cp .env.example .env

# Required: OpenAI API key for GPT-4o-mini promo extraction
OPENAI_API_KEY=sk-proj-...

# Database (defaults match docker-compose.yml)
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1234
DB_NAME=promotions_db

# Scraping schedule (hours between automatic crawl-all runs)
SCRAPE_INTERVAL_HOURS=6

# Cloudflare Tunnel Token (from Zero Trust dashboard)
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Set to 0 to enable semantic deduplication (requires ~500 MB RAM for model download)
SKIP_EMBEDDING_INIT=1

# Google Maps & Places API key (for the Google Reviews module)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
